<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ============================================================
         SYMPTOM AREA
         ============================================================ -->
    <record id="view_jinstage_repair_symptom_area_list" model="ir.ui.view">
        <field name="name">jinstage.repair.symptom.area.list</field>
        <field name="model">jinstage.repair.symptom.area</field>
        <field name="arch" type="xml">
            <list editable="top">
                <field name="name"/>
                <field name="code"/>
                <field name="active" optional="show"/>
            </list>
        </field>
    </record>

    <record id="view_jinstage_repair_symptom_area_form" model="ir.ui.view">
        <field name="name">jinstage.repair.symptom.area.form</field>
        <field name="model">jinstage.repair.symptom.area</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="code"/>
                        <field name="active"/>
                    </group>
                    <group string="Description">
                        <field name="description" nolabel="1"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

