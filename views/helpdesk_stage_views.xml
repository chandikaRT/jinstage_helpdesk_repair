<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Standalone form view for Repair Stages (includes company_id) -->
    <record id="view_jinstage_stage_form" model="ir.ui.view">
        <field name="name">jinstage.helpdesk.stage.form</field>
        <field name="model">helpdesk.stage</field>
        <field name="arch" type="xml">
            <form string="Stage">
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="sequence"/>
                        <field name="company_id"/>
                        <field name="fold"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Standalone tree/list view for Repair Stages -->
    <record id="view_jinstage_stage_tree" model="ir.ui.view">
        <field name="name">jinstage.helpdesk.stage.tree</field>
        <field name="model">helpdesk.stage</field>
        <field name="arch" type="xml">
            <tree string="Stages">
                <field name="name"/>
                <field name="sequence"/>
                <field name="company_id" optional="show"/>
                <field name="fold"/>
            </tree>
        </field>
    </record>
</odoo>
