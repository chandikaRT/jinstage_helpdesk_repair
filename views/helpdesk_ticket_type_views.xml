<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Standalone form view for Repair Ticket Types -->
    <record id="view_jinstage_ticket_type_form" model="ir.ui.view">
        <field name="name">jinstage.helpdesk.ticket.type.form</field>
        <field name="model">helpdesk.ticket.type</field>
        <field name="arch" type="xml">
            <form string="Ticket Type">
                <sheet>
                    <group>
                        <field name="name"/>
                    </group>
                    <group string="Repair Classification">
                        <field name="is_rug" string="RUG / Under Warranty"/>
                        <field name="is_rug_confirmed" string="RUG Confirmed (Full Approval Workflow)"/>
                        <field name="is_with_serial_no" string="Requires Serial Number Tracking"/>
                        <field name="is_without_serial_no" string="No Serial Number Required"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Standalone list view for Repair Ticket Types -->
    <record id="view_jinstage_ticket_type_list" model="ir.ui.view">
        <field name="name">jinstage.helpdesk.ticket.type.list</field>
        <field name="model">helpdesk.ticket.type</field>
        <field name="arch" type="xml">
            <list string="Ticket Types">
                <field name="name"/>
                <field name="is_rug" string="RUG/Warranty"/>
                <field name="is_rug_confirmed" string="RUG Confirmed"/>
                <field name="is_with_serial_no" string="With Serial No"/>
                <field name="is_without_serial_no" string="Without Serial No"/>
            </list>
        </field>
    </record>
</odoo>
